{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "zig build coverage",
      "type": "shell",
      "command": "zig",
      "args": [
        "build",
        "coverage",
        "-Dembed-c=true",
        "-Dopenvpn=true",
        "-Dwireguard=true",
        "-Dopenssl-include=../.build/artifacts/openssl-apple/openssl/openssl.xcframework/macos-arm64_x86_64/openssl.framework/Headers",
        "-Dwg-go-include=../.build/artifacts/wg-go-apple/wg-go/wg-go.xcframework/macos-arm64_x86_64/wg_go.framework/Headers"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$zig",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
