{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "zig build",
      "type": "shell",
      "command": "zig",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$zig",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "zig build coverage",
      "type": "shell",
      "command": "zig",
      "args": [
        "build",
        "coverage",
        "-Dembed-c=true"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$zig",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
  ]
}
