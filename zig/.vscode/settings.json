{
  "zig.path": "zig",
  "zig.zls.enabled": "on",
  "zig.formattingProvider": "zls",
  "zig.buildOnSaveProvider": "zls",
  "zig.buildOnSaveArgs": [
    "check"
  ],
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.zon": "zig"
  },
  "files.watcherExclude": {
    "**/.zig-cache/**": true,
    "**/zig-out/**": true
  },
  "search.exclude": {
    "**/.zig-cache": true,
    "**/zig-out": true
  }
}
